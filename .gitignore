# ──────────────────────────────────────────────────────────────
# Root .gitignore for yi-deploy monorepo
# Covers both backend (Python) and frontend (Node) plus IDE/OS noise.
# ──────────────────────────────────────────────────────────────

# ── Secrets & environment ─────────────────────────────────────
# Never commit real env files. .env.example (template) IS committed.
.env
.env.local
.env.*.local
!.env.example
*.pem
*.key

# ── Python (backend/) ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual envs
venv/
.venv/
env/
ENV/

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/

# SQLite local dev DBs (Railway volume is remote, these are local scratch)
*.db
*.sqlite
*.sqlite3
backend/data/*.db
backend/data/*.sqlite*

# ── Node / Vite (frontend/) ───────────────────────────────────
node_modules/
dist/
dist-ssr/
.vite/
*.local
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript incremental build info — regenerated on build, don't commit
*.tsbuildinfo

# ── IDE / OS ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Railway CLI local artefacts ───────────────────────────────
.railway/
